#!/bin/bash
# gh prs - List PRs with status and CI info (colored, clickable)
# PR colors: grey=draft, green=approved, yellow=pending review, magenta=changes requested, red=conflicts
# PR numbers and Linear issue IDs are clickable (OSC 8 hyperlinks) - Ctrl+click to open in browser
#
# Usage: gh prs [--watch [SECONDS]]
#   --watch         Refresh every 15 seconds (default)
#   --watch N       Refresh every N seconds

WATCH=0
INTERVAL=15

# Debug: uncomment to see args
# echo "DEBUG: args=[$*] count=$#" >&2

while [[ $# -gt 0 ]]; do
  case $1 in
    --watch|-w)
      WATCH=1
      if [[ $2 =~ ^[0-9]+$ ]]; then
        INTERVAL=$2
        shift
      fi
      shift
      ;;
    *)
      shift
      ;;
  esac
done

fetch_prs() {
  local REPO_URL OWNER REPO TERM_WIDTH TITLE_WIDTH PR_JSON UNRES_JSON QUERY pr_aliases num
  IFS=$'\t' read -r OWNER REPO REPO_URL < <(gh repo view --json owner,name,url -q '[.owner.login, .name, .url] | @tsv')
  GRAPHITE_BASE="https://app.graphite.dev/github/pr/${OWNER}/${REPO}"
  TERM_WIDTH=$(tput cols 2>/dev/null || echo 120)
  # Fixed columns: PR(6) + sep(2) + LINEAR(9) + sep(2) + CI(8) + sep(2) + UNRES(5) + sep(2) = 36
  TITLE_WIDTH=$((TERM_WIDTH - 36))
  [[ $TITLE_WIDTH -lt 20 ]] && TITLE_WIDTH=20

  PR_JSON=$(gh pr list --author @me --state open --json number,title,isDraft,reviewDecision,mergeable,statusCheckRollup,headRefName)

  # Single aliased GraphQL call for unresolved review-thread counts (avoids N+1).
  pr_aliases=""
  while IFS= read -r num; do
    [[ -z "$num" ]] && continue
    pr_aliases+="    p${num}: pullRequest(number: ${num}) { reviewThreads(first: 100) { nodes { isResolved } } }"$'\n'
  done < <(echo "$PR_JSON" | jq -r '.[].number')

  if [[ -n "$pr_aliases" ]]; then
    QUERY="query { repository(owner: \"${OWNER}\", name: \"${REPO}\") {"$'\n'"${pr_aliases}  } }"
    UNRES_JSON=$(gh api graphql -f query="$QUERY" 2>/dev/null || echo '{}')
  else
    UNRES_JSON='{}'
  fi

  echo "$PR_JSON" | \
    jq -r --argjson unres "$UNRES_JSON" '
      ($unres.data.repository // {}) as $repo |
      .[] |
      (($repo["p\(.number)"].reviewThreads.nodes // [])
        | map(select(.isResolved == false))
        | length) as $unresolved |
      [
      (.number | tostring),
      (if .isDraft then "draft"
       elif .mergeable == "CONFLICTING" then "conflict"
       elif .reviewDecision == "CHANGES_REQUESTED" then "changes"
       elif .reviewDecision == "APPROVED" then "approved"
       else "pending" end),
      # Drop non-CI meta-checks (e.g. Graphite mergeability, which stays pending
      # on stacked PRs until the downstack merges) before deciding pass/running/fail.
      (if .statusCheckRollup == null or .statusCheckRollup == [] then "pending"
       else (.statusCheckRollup
         | map(select(((.name // .context) // "") | test("^Graphite / mergeability_check$") | not))
         | if length == 0 then "pass"
           elif any(.status == "IN_PROGRESS" or .status == "QUEUED" or .status == "PENDING") then "running"
           elif any(.conclusion == "FAILURE" or .conclusion == "failure") then "fail"
           else "pass" end) end),
      # Extract Linear issue ID from branch name (e.g., "john/eng-123-foo" -> "ENG-123")
      (.headRefName | (capture("(?<team>[a-zA-Z]+)-(?<num>[0-9]+)") | "\(.team | ascii_upcase)-\(.num)") // ""),
      ($unresolved | tostring),
      .title
    ] | @tsv' | \
    awk -F'\t' -v graphite_base="$GRAPHITE_BASE" -v title_width="$TITLE_WIDTH" '
      BEGIN {
        printf "%-6s  %-9s  %-8s  %-5s  %s\n", "PR", "LINEAR", "CI", "UNRES", "TITLE"
        printf "%-6s  %-9s  %-8s  %-5s  %s\n", "------", "---------", "--------", "-----", "-----"
      }
      {
        # Visible text (unpadded). Padding is added AFTER hyperlink/color escapes
        # so trailing spaces are not part of the clickable region.
        pr_visible = "#" $1
        linear_visible = ($4 != "" ? $4 : "-")
        ci_visible = $3
        unres_visible = ($5 != "0" ? $5 : "-")

        pr_pad = sprintf("%*s", 6 - length(pr_visible), "")
        linear_pad = sprintf("%*s", 9 - length(linear_visible), "")
        ci_pad = sprintf("%*s", 8 - length(ci_visible), "")
        unres_pad = sprintf("%*s", 5 - length(unres_visible), "")

        # Truncate title to available width
        title = substr($6, 1, title_width)

        # OSC 8 hyperlink: \033]8;;URL\033\\TEXT\033]8;;\033\\
        url = graphite_base "/" $1
        link_start = "\033]8;;" url "\033\\"
        link_end = "\033]8;;\033\\"

        # Color PR number based on status (with clickable link); pad outside link.
        if ($2 == "draft") pr = link_start "\033[90m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "approved") pr = link_start "\033[32m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "pending") pr = link_start "\033[33m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "changes") pr = link_start "\033[35m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "conflict") pr = link_start "\033[31m" pr_visible "\033[0m" link_end pr_pad
        else pr = link_start pr_visible link_end pr_pad

        # Color CI status
        if (ci_visible ~ /pass/) ci = "\033[32m" ci_visible "\033[0m" ci_pad
        else if (ci_visible ~ /fail/) ci = "\033[31m" ci_visible "\033[0m" ci_pad
        else ci = "\033[33m" ci_visible "\033[0m" ci_pad

        # Color UNRES count: red when there are open threads, grey "-" when zero
        if ($5 != "0") unres = "\033[31m" unres_visible "\033[0m" unres_pad
        else           unres = "\033[90m" unres_visible "\033[0m" unres_pad

        # Linear issue as clickable hyperlink; pad outside link.
        if ($4 != "") {
          linear_url = "https://linear.app/antimetal/issue/" $4
          linear = "\033]8;;" linear_url "\033\\\033[36m" linear_visible "\033[0m\033]8;;\033\\" linear_pad
        } else {
          linear = "\033[90m" linear_visible "\033[0m" linear_pad
        }

        printf "%s  %s  %s  %s  %s\n", pr, linear, ci, unres, title
      }'
}

if [[ $WATCH -eq 1 ]]; then
  # Enter alternate screen buffer + hide cursor; restore both on exit.
  printf '\033[?1049h\033[H'
  tput civis
  trap 'tput cnorm; printf "\033[?1049l"; exit 0' INT TERM EXIT
  while true; do
    output=$(fetch_prs)
    printf '\033[H\033[2J'  # home + clear screen
    printf '\033[90m[%s] Refreshing every %ss - Ctrl+C to stop\033[0m\n\n' "$(date +%H:%M:%S)" "$INTERVAL"
    echo "$output"
    sleep "$INTERVAL"
  done
else
  fetch_prs
fi
