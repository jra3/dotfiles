#!/bin/bash
# gh prs - List PRs with status and CI info (colored, clickable)
# PR colors: grey=draft, green=approved, yellow=pending review, magenta=changes requested, red=conflicts
# PR numbers and Linear issue IDs are clickable (OSC 8 hyperlinks) - Ctrl+click to open in browser
#
# Usage: gh prs [--watch [SECONDS]] [--branch] [--tree] [--mode MODE]
#   --watch         Refresh every 15 seconds (default)
#   --watch N       Refresh every N seconds
#   --branch, -b    Show branch names instead of PR titles
#   --tree, -t      Render the Graphite stack tree (`gt ls`) with right-justified
#                   PR# (review-state colored, CI-glyph prefixed) and the current
#                   metric. Combinable with --watch. Mutually exclusive with
#                   --branch.
#   --mode MODE     Metric column to display:
#                     unres (default)  unresolved review threads
#                     diff             lines added/removed (+X/-Y)
# In --watch mode, press 'm' to cycle modes, 'q' to quit.

# Ensure ${#var} counts characters (not bytes) for multi-byte glyphs.
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# Echo the printable-character count of a string, ignoring ANSI CSI sequences
# and OSC8 hyperlink wrappers. Requires LC_ALL=*.UTF-8 for multi-byte chars.
_visible_width() {
  local stripped
  stripped=$(printf '%s' "$1" | sed -E $'s/\e\\[[0-9;]*[a-zA-Z]//g; s/\e\\]8;;[^\a\e]*(\a|\e\\\\)//g')
  printf '%d' "${#stripped}"
}

# Given a `gt ls` line, echo the branch name.
# First strips ANSI CSI/OSC8 escapes (gt may emit colors when FORCE_COLOR is
# set), then strips leading tree-drawing chars/spaces and any trailing
# parenthesized annotations. Branch names start with an ASCII letter.
_extract_branch_name() {
  printf '%s' "$1" | sed -E $'s/\e\\[[0-9;]*[a-zA-Z]//g; s/\e\\]8;;[^\a\e]*(\a|\e\\\\)//g; s/^[^A-Za-z]*//; s/( *\\([^)]*\\))+ *$//'
}

# Build the right-side PR cell. Returns "<visible_width>\t<styled_text>".
# Args: pr_num review_state ci_state mode unres adds dels graphite_base
#   review_state ∈ {draft,approved,pending,changes,conflict,""}
#   ci_state ∈ {pass,running,fail,""}
#   mode ∈ {unres,diff}
_format_pr_cell() {
  local pr_num=$1 review=$2 ci=$3 mode=$4 unres=$5 adds=$6 dels=$7 base=$8
  local ESC=$'\e'

  local glyph glyph_c
  case "$ci" in
    pass)    glyph='●'; glyph_c=32 ;;
    running) glyph='◐'; glyph_c=33 ;;
    fail)    glyph='✗'; glyph_c=31 ;;
    *)       glyph=' '; glyph_c=0 ;;
  esac

  local pr_c
  case "$review" in
    draft)    pr_c=90 ;;
    approved) pr_c=32 ;;
    pending)  pr_c=33 ;;
    changes)  pr_c=35 ;;
    conflict) pr_c=31 ;;
    *)        pr_c=0 ;;
  esac

  local metric_text metric_styled metric_width
  case "$mode" in
    diff)
      [[ $adds =~ ^[0-9]+$ ]] || adds=0
      [[ $dels =~ ^[0-9]+$ ]] || dels=0
      local adds_str="+${adds}" dels_str="-${dels}"
      # Right-align "+adds" in 5 and left-align "-dels" in 5 so '/' is in a
      # fixed column. Overflows (5+ digit sides) cause this row to widen by
      # the overflow amount; other rows still align with each other.
      local adds_pad='' dels_pad='' adds_pad_len dels_pad_len
      adds_pad_len=$(( 5 - ${#adds_str} ))
      dels_pad_len=$(( 5 - ${#dels_str} ))
      (( adds_pad_len < 0 )) && adds_pad_len=0
      (( dels_pad_len < 0 )) && dels_pad_len=0
      (( adds_pad_len > 0 )) && printf -v adds_pad '%*s' "$adds_pad_len" ''
      (( dels_pad_len > 0 )) && printf -v dels_pad '%*s' "$dels_pad_len" ''
      metric_text="${adds_pad}${adds_str}/${dels_str}${dels_pad}"
      metric_styled="${adds_pad}${ESC}[32m${adds_str}${ESC}[0m/${ESC}[31m${dels_str}${ESC}[0m${dels_pad}"
      metric_width=11
      ;;
    *)
      if [[ $unres =~ ^[0-9]+$ ]] && (( unres > 0 )); then
        metric_text=$unres
        metric_styled="${ESC}[31m${unres}${ESC}[0m"
      else
        metric_text='-'
        metric_styled="${ESC}[90m-${ESC}[0m"
      fi
      metric_width=5
      ;;
  esac

  # Right-align metric and #PR within fixed-width sub-columns so every row's
  # cell has identical visible width, making right edges align in _render_tree.
  local metric_pad='' metric_pad_len=$(( metric_width - ${#metric_text} ))
  (( metric_pad_len < 0 )) && metric_pad_len=0
  (( metric_pad_len > 0 )) && printf -v metric_pad '%*s' "$metric_pad_len" ''

  local pr_width=5 pr_pad='' pr_pad_len
  pr_pad_len=$(( pr_width - 1 - ${#pr_num} ))
  (( pr_pad_len < 0 )) && pr_pad_len=0
  (( pr_pad_len > 0 )) && printf -v pr_pad '%*s' "$pr_pad_len" ''

  local link_start="${ESC}]8;;${base}/${pr_num}${ESC}\\"
  local link_end="${ESC}]8;;${ESC}\\"
  local glyph_part="${ESC}[${glyph_c}m${glyph}${ESC}[0m"
  local pr_part="${link_start}${ESC}[${pr_c}m#${pr_num}${ESC}[0m${link_end}"

  local plain="${glyph} ${pr_pad}#${pr_num}  ${metric_pad}${metric_text}"
  printf '%d\t%s %s%s  %s%s' "${#plain}" "$glyph_part" "$pr_pad" "$pr_part" "$metric_pad" "$metric_styled"
}

# Render the joined tree.
# Args: gt_output pr_tsv graphite_base term_width mode
#   pr_tsv has one row per PR, tab-separated:
#     branch \t num \t review \t ci \t unres \t adds \t dels
#   gt_output is the captured stdout of `gt ls` (no color escapes when piped).
_render_tree() {
  local gt_output=$1 pr_tsv=$2 base=$3 term_width=$4 mode=$5
  local -A prmap=()

  if [[ -n "$pr_tsv" ]]; then
    while IFS=$'\t' read -r branch num review ci unres adds dels; do
      [[ -z "$branch" ]] && continue
      prmap[$branch]="${num}	${review}	${ci}	${unres}	${adds}	${dels}"
    done <<< "$pr_tsv"
  fi

  [[ -z "$gt_output" ]] && return 0

  local line branch num review ci unres adds dels cell_w cell pad left_w
  while IFS= read -r line; do
    branch=$(_extract_branch_name "$line")
    if [[ -n "$branch" && -n "${prmap[$branch]+x}" ]]; then
      IFS=$'\t' read -r num review ci unres adds dels <<< "${prmap[$branch]}"
      IFS=$'\t' read -r cell_w cell < <(_format_pr_cell "$num" "$review" "$ci" "$mode" "$unres" "$adds" "$dels" "$base")
      left_w=$(_visible_width "$line")
      pad=$(( term_width - left_w - cell_w ))
      (( pad < 2 )) && pad=2
      printf '%s%*s%s\n' "$line" "$pad" '' "$cell"
    else
      printf '%s\n' "$line"
    fi
  done <<< "$gt_output"
}

# Cached state populated by fetch_*, consumed by print_*.
# Lets watch-mode cycle the metric mode without re-hitting the network.
_FETCHED_GRAPHITE_BASE=""
_FETCHED_PRS_TSV=""
_FETCHED_GT_OUT=""
_FETCHED_GT_ERR=""
_FETCHED_TREE_PR_TSV=""

# Build the aliased GraphQL subquery body for per-PR detail lookups.
# Emits one `p<num>: pullRequest(number: <num>) { ... }` block per PR number on
# stdin, fetching unresolved review threads plus the status-check rollup with
# each context's `isRequired` flag.
#
# `isRequired(pullRequestNumber:)` only reflects branch protection on the PR's
# actual base. For stacked PRs (base = an intermediate branch) it returns false
# for everything, even when the checks would block on merge to the default
# branch. Callers compensate by taking the *union* of required-names across all
# returned PRs — any sibling PR targeting the default branch reveals the set.
_pr_detail_aliases() {
  local pr_json=$1 num aliases=""
  while IFS= read -r num; do
    [[ -z "$num" ]] && continue
    aliases+="    p${num}: pullRequest(number: ${num}) {
      reviewThreads(first: 100) { nodes { isResolved } }
      statusCheckRollup {
        contexts(first: 100) {
          nodes {
            __typename
            ... on CheckRun {
              name
              status
              conclusion
              isRequired(pullRequestNumber: ${num})
            }
            ... on StatusContext {
              context
              state
              isRequired(pullRequestNumber: ${num})
            }
          }
        }
      }
    }
"
  done < <(echo "$pr_json" | jq -r '.[].number')
  printf '%s' "$aliases"
}

fetch_prs() {
  local REPO_URL OWNER REPO PR_JSON DETAILS_JSON QUERY pr_aliases
  IFS=$'\t' read -r OWNER REPO REPO_URL < <(gh repo view --json owner,name,url -q '[.owner.login, .name, .url] | @tsv')
  _FETCHED_GRAPHITE_BASE="https://app.graphite.dev/github/pr/${OWNER}/${REPO}"

  PR_JSON=$(gh pr list --author @me --state open --json number,title,isDraft,reviewDecision,mergeable,headRefName,updatedAt,additions,deletions \
    | jq 'sort_by(.updatedAt) | reverse')

  pr_aliases=$(_pr_detail_aliases "$PR_JSON")
  if [[ -n "$pr_aliases" ]]; then
    QUERY="query { repository(owner: \"${OWNER}\", name: \"${REPO}\") {"$'\n'"${pr_aliases}  } }"
    DETAILS_JSON=$(gh api graphql -f query="$QUERY" 2>/dev/null || echo '{}')
  else
    DETAILS_JSON='{}'
  fi

  _FETCHED_PRS_TSV=$(echo "$PR_JSON" | \
    jq -r --argjson details "$DETAILS_JSON" '
      ($details.data.repository // {}) as $repo |
      # Build canonical required-check set as union across all PRs.
      # GraphQL only marks isRequired=true for contexts on PRs whose base has
      # protection (i.e. PRs targeting main); stacked PRs reuse that set by name.
      ([$repo | to_entries[] | .value.statusCheckRollup.contexts.nodes // [] | .[]
         | select(.isRequired == true)
         | (.name // .context) // empty]
        | unique
        | map({(.): true}) | add // {}) as $req_set |
      .[] |
      $repo["p\(.number)"] as $pr |
      (($pr.reviewThreads.nodes // [])
        | map(select(.isResolved == false))
        | length) as $unresolved |
      (($pr.statusCheckRollup.contexts.nodes // [])
        | map(select($req_set[(.name // .context) // ""] == true))) as $req |
      [
      (.number | tostring),
      (if .isDraft then "draft"
       elif .mergeable == "CONFLICTING" then "conflict"
       elif .reviewDecision == "CHANGES_REQUESTED" then "changes"
       elif .reviewDecision == "APPROVED" then "approved"
       else "pending" end),
      # CI state derived from required-only contexts. No required checks (or no
      # rollup yet) → "pending" → blank glyph, rather than implying success.
      (if ($req | length) == 0 then "pending"
       elif any($req[];
         (.__typename == "CheckRun" and (.status == "QUEUED" or .status == "IN_PROGRESS" or .status == "PENDING" or .status == "WAITING" or .status == "REQUESTED"))
         or (.__typename == "StatusContext" and (.state == "EXPECTED" or .state == "PENDING"))
       ) then "running"
       elif any($req[];
         (.__typename == "CheckRun" and (.conclusion == "FAILURE" or .conclusion == "TIMED_OUT" or .conclusion == "CANCELLED" or .conclusion == "ACTION_REQUIRED" or .conclusion == "STARTUP_FAILURE" or .conclusion == "STALE"))
         or (.__typename == "StatusContext" and (.state == "FAILURE" or .state == "ERROR"))
       ) then "fail"
       else "pass" end),
      # Extract Linear issue ID from branch name (e.g., "john/eng-123-foo" -> "ENG-123")
      (.headRefName | (capture("(?<team>[a-zA-Z]+)-(?<num>[0-9]+)") | "\(.team | ascii_upcase)-\(.num)") // ""),
      ($unresolved | tostring),
      (.additions | tostring),
      (.deletions | tostring),
      .title,
      .headRefName
    ] | @tsv')
}

print_prs() {
  local TERM_WIDTH TITLE_WIDTH METRIC_WIDTH
  TERM_WIDTH=$(tput cols 2>/dev/null || echo 120)
  case "$MODE" in
    diff) METRIC_WIDTH=11 ;;
    *)    METRIC_WIDTH=5 ;;
  esac
  # Fixed: PR(6) + sep(2) + LINEAR(9) + sep(2) + CI(8) + sep(2) + METRIC + sep(2) = 31 + METRIC
  TITLE_WIDTH=$((TERM_WIDTH - 31 - METRIC_WIDTH))
  [[ $TITLE_WIDTH -lt 20 ]] && TITLE_WIDTH=20

  printf '%s' "$_FETCHED_PRS_TSV" | \
    awk -F'\t' -v graphite_base="$_FETCHED_GRAPHITE_BASE" -v title_width="$TITLE_WIDTH" -v show_branch="$SHOW_BRANCH" -v mode="$MODE" -v metric_width="$METRIC_WIDTH" '
      BEGIN {
        metric_header = (mode == "diff") ? "DIFF" : "UNRES"
        metric_dashes = ""
        for (i = 0; i < metric_width; i++) metric_dashes = metric_dashes "-"
        last_header = show_branch == "1" ? "BRANCH" : "TITLE"
        printf "%-6s  %-9s  %-8s  %-*s  %s\n", "PR", "LINEAR", "CI", metric_width, metric_header, last_header
        printf "%-6s  %-9s  %-8s  %-*s  %s\n", "------", "---------", "--------", metric_width, metric_dashes, "-----"
      }
      {
        # Visible text (unpadded). Padding is added AFTER hyperlink/color escapes
        # so trailing spaces are not part of the clickable region.
        pr_visible = "#" $1
        linear_visible = ($4 != "" ? $4 : "-")
        ci_visible = $3

        if (mode == "diff") {
          adds = ($6 == "" ? "0" : $6)
          dels = ($7 == "" ? "0" : $7)
          adds_str = "+" adds
          dels_str = "-" dels
          adds_pad_len = 5 - length(adds_str)
          dels_pad_len = 5 - length(dels_str)
          if (adds_pad_len < 0) adds_pad_len = 0
          if (dels_pad_len < 0) dels_pad_len = 0
          adds_pad = sprintf("%*s", adds_pad_len, "")
          dels_pad = sprintf("%*s", dels_pad_len, "")
          metric_visible = adds_pad adds_str "/" dels_str dels_pad
          metric_styled = adds_pad "\033[32m" adds_str "\033[0m/\033[31m" dels_str "\033[0m" dels_pad
        } else {
          metric_visible = ($5 != "0" ? $5 : "-")
          if ($5 != "0") metric_styled = "\033[31m" metric_visible "\033[0m"
          else           metric_styled = "\033[90m" metric_visible "\033[0m"
        }

        pr_pad = sprintf("%*s", 6 - length(pr_visible), "")
        linear_pad = sprintf("%*s", 9 - length(linear_visible), "")
        ci_pad = sprintf("%*s", 8 - length(ci_visible), "")
        metric_pad_len = metric_width - length(metric_visible)
        if (metric_pad_len < 0) metric_pad_len = 0
        metric_pad = sprintf("%*s", metric_pad_len, "")

        # Truncate title or branch to available width
        title = substr(show_branch == "1" ? $9 : $8, 1, title_width)

        # OSC 8 hyperlink: \033]8;;URL\033\\TEXT\033]8;;\033\\
        url = graphite_base "/" $1
        link_start = "\033]8;;" url "\033\\"
        link_end = "\033]8;;\033\\"

        # Color PR number based on status (with clickable link); pad outside link.
        if ($2 == "draft") pr = link_start "\033[90m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "approved") pr = link_start "\033[32m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "pending") pr = link_start "\033[33m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "changes") pr = link_start "\033[35m" pr_visible "\033[0m" link_end pr_pad
        else if ($2 == "conflict") pr = link_start "\033[31m" pr_visible "\033[0m" link_end pr_pad
        else pr = link_start pr_visible link_end pr_pad

        # Color CI status
        if (ci_visible ~ /pass/) ci = "\033[32m" ci_visible "\033[0m" ci_pad
        else if (ci_visible ~ /fail/) ci = "\033[31m" ci_visible "\033[0m" ci_pad
        else ci = "\033[33m" ci_visible "\033[0m" ci_pad

        metric = metric_styled metric_pad

        # Linear issue as clickable hyperlink; pad outside link.
        if ($4 != "") {
          linear_url = "https://linear.app/antimetal/issue/" $4
          linear = "\033]8;;" linear_url "\033\\\033[36m" linear_visible "\033[0m\033]8;;\033\\" linear_pad
        } else {
          linear = "\033[90m" linear_visible "\033[0m" linear_pad
        }

        printf "%s  %s  %s  %s  %s\n", pr, linear, ci, metric, title
      }'
}

fetch_tree() {
  local REPO_URL OWNER REPO PR_JSON DETAILS_JSON QUERY pr_aliases
  IFS=$'\t' read -r OWNER REPO REPO_URL < <(gh repo view --json owner,name,url -q '[.owner.login, .name, .url] | @tsv')
  _FETCHED_GRAPHITE_BASE="https://app.graphite.dev/github/pr/${OWNER}/${REPO}"

  if ! _FETCHED_GT_OUT=$(FORCE_COLOR=1 gt ls 2>&1); then
    _FETCHED_GT_ERR=$_FETCHED_GT_OUT
    _FETCHED_GT_OUT=""
    _FETCHED_TREE_PR_TSV=""
    return 1
  fi
  _FETCHED_GT_ERR=""

  PR_JSON=$(gh pr list --author @me --state open \
    --json number,title,isDraft,reviewDecision,mergeable,headRefName,updatedAt,additions,deletions)

  pr_aliases=$(_pr_detail_aliases "$PR_JSON")
  if [[ -n "$pr_aliases" ]]; then
    QUERY="query { repository(owner: \"${OWNER}\", name: \"${REPO}\") {"$'\n'"${pr_aliases}  } }"
    DETAILS_JSON=$(gh api graphql -f query="$QUERY" 2>/dev/null || echo '{}')
  else
    DETAILS_JSON='{}'
  fi

  _FETCHED_TREE_PR_TSV=$(echo "$PR_JSON" | jq -r --argjson details "$DETAILS_JSON" '
    ($details.data.repository // {}) as $repo |
    # Required-check set as union across all PRs (see fetch_prs comment).
    ([$repo | to_entries[] | .value.statusCheckRollup.contexts.nodes // [] | .[]
       | select(.isRequired == true)
       | (.name // .context) // empty]
      | unique
      | map({(.): true}) | add // {}) as $req_set |
    .[] |
    $repo["p\(.number)"] as $pr |
    (($pr.reviewThreads.nodes // [])
      | map(select(.isResolved == false))
      | length) as $unresolved |
    (($pr.statusCheckRollup.contexts.nodes // [])
      | map(select($req_set[(.name // .context) // ""] == true))) as $req |
    [
      .headRefName,
      (.number | tostring),
      (if .isDraft then "draft"
       elif .mergeable == "CONFLICTING" then "conflict"
       elif .reviewDecision == "CHANGES_REQUESTED" then "changes"
       elif .reviewDecision == "APPROVED" then "approved"
       else "pending" end),
      # CI state derived from required-only contexts (see fetch_prs).
      (if ($req | length) == 0 then "pending"
       elif any($req[];
         (.__typename == "CheckRun" and (.status == "QUEUED" or .status == "IN_PROGRESS" or .status == "PENDING" or .status == "WAITING" or .status == "REQUESTED"))
         or (.__typename == "StatusContext" and (.state == "EXPECTED" or .state == "PENDING"))
       ) then "running"
       elif any($req[];
         (.__typename == "CheckRun" and (.conclusion == "FAILURE" or .conclusion == "TIMED_OUT" or .conclusion == "CANCELLED" or .conclusion == "ACTION_REQUIRED" or .conclusion == "STARTUP_FAILURE" or .conclusion == "STALE"))
         or (.__typename == "StatusContext" and (.state == "FAILURE" or .state == "ERROR"))
       ) then "fail"
       else "pass" end),
      ($unresolved | tostring),
      (.additions | tostring),
      (.deletions | tostring)
    ] | @tsv')
}

print_tree() {
  local TERM_WIDTH
  if [[ -n "$_FETCHED_GT_ERR" ]]; then
    printf '%s\n' "$_FETCHED_GT_ERR"
    echo "Run 'gt track' if this branch is not yet tracked."
    return 1
  fi
  TERM_WIDTH=$(tput cols 2>/dev/null || echo 120)
  _render_tree "$_FETCHED_GT_OUT" "$_FETCHED_TREE_PR_TSV" "$_FETCHED_GRAPHITE_BASE" "$TERM_WIDTH" "$MODE"
}

# Available metric modes in cycle order.
MODES=(unres diff)

_next_mode() {
  local current=$1 i
  for (( i = 0; i < ${#MODES[@]}; i++ )); do
    if [[ ${MODES[$i]} == "$current" ]]; then
      echo "${MODES[$(( (i + 1) % ${#MODES[@]} ))]}"
      return
    fi
  done
  echo "${MODES[0]}"
}

main() {
  WATCH=0
  INTERVAL=15
  SHOW_BRANCH=0
  TREE=0
  MODE=unres

  while [[ $# -gt 0 ]]; do
    case $1 in
      --watch|-w)
        WATCH=1
        if [[ ${2:-} =~ ^[0-9]+$ ]]; then
          INTERVAL=$2
          shift
        fi
        shift
        ;;
      --branch|-b)
        SHOW_BRANCH=1
        shift
        ;;
      --tree|-t)
        TREE=1
        shift
        ;;
      --mode|-m)
        if [[ -z ${2:-} ]]; then
          echo "error: --mode requires an argument (one of: ${MODES[*]})" >&2
          return 1
        fi
        MODE=$2
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done

  if (( TREE == 1 && SHOW_BRANCH == 1 )); then
    echo "error: --tree and --branch are mutually exclusive" >&2
    return 1
  fi

  local valid_mode=0 m
  for m in "${MODES[@]}"; do
    [[ $m == "$MODE" ]] && valid_mode=1 && break
  done
  if (( valid_mode == 0 )); then
    echo "error: unknown --mode '$MODE' (expected one of: ${MODES[*]})" >&2
    return 1
  fi

  if (( WATCH == 1 )); then
    # Enter alternate screen buffer + hide cursor; switch tty to non-canonical
    # so a single keypress returns from `read` without waiting for newline.
    printf '\033[?1049h\033[H'
    tput civis
    [[ -t 0 ]] && stty -icanon -echo min 1 time 0 2>/dev/null
    trap '[[ -t 0 ]] && stty icanon echo 2>/dev/null; tput cnorm; printf "\033[?1049l"; exit 0' INT TERM EXIT

    local output key now elapsed remaining last_fetch=0
    while true; do
      now=$(date +%s)
      if (( now - last_fetch >= INTERVAL )); then
        if (( TREE == 1 )); then
          fetch_tree || true
        else
          fetch_prs || true
        fi
        last_fetch=$now
      fi

      if (( TREE == 1 )); then
        output=$(print_tree)
      else
        output=$(print_prs)
      fi
      printf '\033[H\033[2J'  # home + clear screen
      printf '\033[90m[%s] Refreshing every %ss - Mode: %s (m=cycle, q=quit)\033[0m\n\n' \
        "$(date +%H:%M:%S)" "$INTERVAL" "$MODE"
      echo "$output"

      elapsed=$(( $(date +%s) - last_fetch ))
      remaining=$(( INTERVAL - elapsed ))
      (( remaining < 1 )) && remaining=1

      key=""
      if IFS= read -rsN1 -t "$remaining" key 2>/dev/null; then
        case "$key" in
          m|M) MODE=$(_next_mode "$MODE") ;;
          q|Q) break ;;
        esac
      fi
    done
  elif (( TREE == 1 )); then
    if ! fetch_tree; then
      printf '%s\n' "$_FETCHED_GT_ERR" >&2
      echo "Run 'gt track' if this branch is not yet tracked." >&2
      return 1
    fi
    print_tree
  else
    fetch_prs
    print_prs
  fi
}

# Only run main if executed directly, not when sourced (e.g. by tests).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  git rev-parse --git-dir >/dev/null 2>&1 || { echo "Not in a git repository" >&2; exit 1; }
  main "$@"
  exit $?
fi
