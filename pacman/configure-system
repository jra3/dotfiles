#!/bin/bash
# Post-install system configuration
# Safe to re-run (idempotent). Requires sudo for some operations.

set -euo pipefail

echo "Configuring system..."

# --- Tailscale ---
if command -v tailscale &>/dev/null; then
    echo "Configuring Tailscale..."
    sudo systemctl enable --now tailscaled
    sudo tailscale set --operator="$USER"
    echo "  Tailscale operator set to $USER"
    echo "  Run 'tailscale up' if not yet authenticated."
else
    echo "  Tailscale not installed, skipping."
fi

# --- SSH: enable + bind to the Tailscale interface only ---
# Requires Tailscale to be up (authenticated) so its address is known. On a
# brand-new machine, run 'tailscale up' first, then re-run this script.
if command -v tailscale &>/dev/null && command -v sshd &>/dev/null; then
    ts_v4="$(tailscale ip -4 2>/dev/null || true)"
    ts_v6="$(tailscale ip -6 2>/dev/null || true)"
    if [ -n "$ts_v4" ]; then
        echo "Binding sshd to Tailscale addresses ($ts_v4${ts_v6:+, $ts_v6})..."
        {
            echo "# Managed by dotfiles configure-system."
            echo "# Bind SSH to the Tailscale interface only (see: tailscale ip)."
            echo "ListenAddress $ts_v4"
            [ -n "$ts_v6" ] && echo "ListenAddress $ts_v6" || true
        } | sudo tee /etc/ssh/sshd_config.d/10-tailscale.conf >/dev/null

        # Order sshd after Tailscale and retry, so it can still bind once the
        # Tailscale address is configured on the interface during boot.
        sudo install -d /etc/systemd/system/sshd.service.d
        printf '%s\n' \
            '[Unit]' \
            'After=tailscaled.service' \
            'Wants=tailscaled.service' \
            '' \
            '[Service]' \
            'Restart=on-failure' \
            'RestartSec=3' \
            | sudo tee /etc/systemd/system/sshd.service.d/10-tailscale.conf >/dev/null

        if sudo sshd -t; then
            sudo systemctl daemon-reload
            sudo systemctl enable sshd
            sudo systemctl restart sshd
            echo "  sshd enabled on boot and bound to Tailscale only."
        else
            echo "  ERROR: sshd config test failed; left previous runtime config in place." >&2
        fi
    else
        echo "  Tailscale not up yet (run 'tailscale up'); skipping SSH setup."
    fi
else
    echo "  sshd or Tailscale not present; skipping SSH setup."
fi

# --- SSH client control sockets ---
# config.shared enables connection multiplexing with `ControlPath ~/.ssh/sockets/cm-%C`.
# ssh won't create the directory itself, so every connection fails until it exists.
echo "Ensuring SSH control-socket dir..."
install -d -m 700 "$HOME/.ssh/sockets"
echo "  ~/.ssh/sockets present."

# --- SSH agent key list (host-local) ---
# ssh-add-keys.service loads the sk keys named in ~/.ssh/agent-keys. Which keys
# belong in the agent varies per host, so the file is host-local (~/.ssh is not
# stowed; it never enters the repo) and each host seeds its own: if the file is
# missing, list every sk private key already on disk. Re-runs never touch an
# existing file, so curate it freely after seeding.
if [ ! -f "$HOME/.ssh/agent-keys" ]; then
    echo "Seeding ~/.ssh/agent-keys from on-disk sk keys..."
    {
        echo "# SK keys to load into the ssh-agent on THIS host (read by ssh-add-keys.service)."
        echo "# One key per line, relative to ~/.ssh (absolute paths also work). '#' comments"
        echo "# and blank lines are ignored; entries whose file is missing are skipped."
        echo "# Host-local: ~/.ssh is not stowed, so this file never enters the dotfiles repo."
        for key in "$HOME"/.ssh/id_*sk*; do
            if [[ $key != *.pub && -f $key ]]; then
                echo "${key##*/}"
            fi
        done
    } > "$HOME/.ssh/agent-keys"
    chmod 600 "$HOME/.ssh/agent-keys"
    echo "  seeded: $(grep -vc '^#' "$HOME/.ssh/agent-keys") key(s). Edit ~/.ssh/agent-keys to curate."
else
    echo "  ~/.ssh/agent-keys already present; leaving it alone."
fi

# --- SSH agent (user) ---
# Run OpenSSH's own ssh-agent (FIDO2/sk-capable, unlike gnome-keyring's) and
# auto-load this machine's YubiKey keys into it at login, so SSH agent
# forwarding (e.g. to am-jallen / chonky) can broker them. SSH_AUTH_SOCK is
# pointed at the socket via ssh/.config/environment.d/ssh-agent.conf.
# ssh-add-keys.service is stowed from the `ssh` package and self-skips (via
# ConditionPathExists) until ~/.ssh/agent-keys exists — seeded just above, so
# ordering here matters.
if command -v ssh-agent &>/dev/null; then
    echo "Configuring SSH agent (user)..."
    systemctl --user enable --now ssh-agent.socket
    if systemctl --user cat ssh-add-keys.service &>/dev/null; then
        systemctl --user enable --now ssh-add-keys.service
        echo "  ssh-agent socket + key auto-load enabled."
    else
        echo "  ssh-agent socket enabled; ssh-add-keys.service not stowed, skipping."
    fi
else
    echo "  ssh-agent not installed, skipping."
fi

# --- Emacs ---
if command -v emacs &>/dev/null; then
    echo "Configuring Emacs daemon..."
    systemctl --user enable --now emacs
    echo "  Emacs daemon enabled."
else
    echo "  Emacs not installed, skipping."
fi

# --- iPhone USB tethering (systemd-networkd) ---
# The iPhone's `ipheth` driver creates an Ethernet-class interface when Personal
# Hotspot is on and the phone is plugged in. DHCP it, with a route metric between
# real Ethernet (100) and Wi-Fi (600) so a tethered phone becomes the default
# route (e.g. on the bus) but still yields to a wired connection. IPv4 only:
# iPhone tether IPv6 is flaky and can stall connections. Extra drivers are listed
# so the same file also covers Android (RNDIS/NCM) if ever needed.
# Requires the `usbmuxd` package (in packages-arch.txt); its udev rule autostarts
# the daemon on plug-in, and pairing ("Trust This Computer") happens on first use.
# NOTE the 15- prefix: systemd-networkd applies only the FIRST matching .network
# file in lexical order. The iPhone tether often appears as `eth0`, which the
# stock 20-ethernet.network (Name=eth*) also matches — so this file must sort
# before it to win, otherwise it's silently shadowed.
echo "Configuring iPhone USB tethering..."
sudo rm -f /etc/systemd/network/25-usb-tether.network  # retired earlier name
printf '%s\n' \
    '[Match]' \
    'Driver=ipheth rndis_host cdc_ncm cdc_ether' \
    '' \
    '[Network]' \
    'DHCP=ipv4' \
    '' \
    '[DHCPv4]' \
    'RouteMetric=200' \
    | sudo tee /etc/systemd/network/15-usb-tether.network >/dev/null
sudo systemctl reload-or-restart systemd-networkd
echo "  Installed /etc/systemd/network/15-usb-tether.network"

# --- Pacman hooks ---
echo "Installing pacman hooks..."
HOOKS_DIR="$(cd "$(dirname "$0")" && pwd)/hooks"
if [ -d "$HOOKS_DIR" ]; then
    sudo cp "$HOOKS_DIR"/*.hook /etc/pacman.d/hooks/
    echo "  Pacman hooks installed."
else
    echo "  No hooks directory found, skipping."
fi

echo "Done!"
