# See https://git-scm.com/docs/git-config

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    what = log --raw --no-merges
    whatchanged = log --raw --no-merges
    # Delete local branches whose PR is MERGED (squash-merge-aware via gh).
    # Skips main/master, the current branch, and worktree-checked-out branches.
    #   --dry-run  preview only          --closed  also list CLOSED-PR branches (never deletes them)
    prune-merged = "!f() { \
        dry=0; closed=0; \
        for a in \"$@\"; do case \"$a\" in --dry-run) dry=1;; --closed) closed=1;; esac; done; \
        cur=$(git symbolic-ref --quiet --short HEAD); \
        for b in $(git for-each-ref --format='%(refname:short)' refs/heads/); do \
            case \"$b\" in main|master|\"$cur\") continue;; esac; \
            git worktree list --porcelain | grep -qxF \"branch refs/heads/$b\" && continue; \
            st=$(gh pr list --head \"$b\" --state all --limit 1 --json state --jq '.[0].state' 2>/dev/null); \
            if [ \"$st\" = MERGED ]; then \
                if [ \"$dry\" = 1 ]; then echo \"would prune (merged): $b\"; \
                else git branch -D \"$b\" >/dev/null 2>&1 && echo \"pruned $b\"; fi; \
            elif [ \"$st\" = CLOSED ] && [ \"$closed\" = 1 ]; then echo \"closed, review manually: $b\"; fi; \
        done; }; f"
[init]
    defaultBranch = master
[pull]
    rebase = true            # Rebase (instead of merge) on pull
[push]
    autoSetupRemote = true   # Automatically set upstream branch on push
[diff]
    algorithm = patience
    colorMoved = plain       # Highlight moved blocks in diffs
    mnemonicPrefix = true    # More intuitive refs in diff output
[commit]
    verbose = true           # Include diff comment in commit message template
    gpgsign = true           # Sign every commit (SSH key on the YubiKey)
[column]
    ui = auto                # Output in columns when possible
[branch]
    sort = -committerdate    # Sort branches by most recent commit first
[tag]
    sort = -version:refname  # Sort version numbers as you would expect
    gpgsign = true           # Sign annotated tags too
[rerere]
    enabled = true           # Record and reuse conflict resolutions
    autoupdate = true        # Apply stored conflict resolutions automatically
[user]
    name = John Allen
    email = github@porcnick.com
    signingkey = ~/.ssh/id_ed25519_sk_gitsign.pub
[gpg]
    format = ssh                          # Sign with an SSH key, not GPG
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers
[blame]
    coloring = highlightRecent

[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    side-by-side = true
    hyperlinks = true

[includeIf "gitdir:~/am/"]
    path = config-work
